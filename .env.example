# ImToLego Enterprise API
# Copy to .env and customize

APP_NAME=ImToLego
APP_VERSION=1.0.0
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=1

UPLOADS_DIR=./uploads
OUTPUTS_DIR=./outputs
MAX_UPLOAD_SIZE_MB=20

# ML
MODEL_ID=stabilityai/TripoSR
MODEL_CONFIG_NAME=config.yaml
MODEL_WEIGHT_NAME=model.ckpt
DEVICE=cuda:0
CHUNK_SIZE=8192
MC_RESOLUTION=256
REMOVE_BG=true
FOREGROUND_RATIO=0.85

# LEGO
LEGO_STUD_DIA_MM=8.0
LEGO_PLATE_HEIGHT_MM=3.2
LEGO_BRICK_HEIGHT_MM=9.6
LEGO_VOXEL_SCALE=0.02
LEGO_WALL_THICKNESS=1

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Logging
LOG_LEVEL=INFO
